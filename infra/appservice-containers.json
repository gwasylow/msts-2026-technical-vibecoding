{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "16455680114641400714"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the App Service plan and web apps. Defaults to the target resource group location."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "asp-techvibecoding-prod",
      "metadata": {
        "description": "App Service plan name used by both web apps."
      }
    },
    "backendAppName": {
      "type": "string",
      "defaultValue": "web-techvibecoding-backend-api",
      "metadata": {
        "description": "Backend web app name."
      }
    },
    "frontendAppName": {
      "type": "string",
      "defaultValue": "web-techvibecoding-frontend",
      "metadata": {
        "description": "Frontend web app name."
      }
    },
    "backendImageRepository": {
      "type": "string",
      "defaultValue": "backend-api",
      "metadata": {
        "description": "Backend container repository name inside Azure Container Registry."
      }
    },
    "backendImageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Backend container tag inside Azure Container Registry."
      }
    },
    "frontendImageRepository": {
      "type": "string",
      "defaultValue": "frontend-webapp",
      "metadata": {
        "description": "Frontend container repository name inside Azure Container Registry."
      }
    },
    "frontendImageTag": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Frontend container tag inside Azure Container Registry."
      }
    },
    "backendImageReference": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional backend container image reference. Leave empty to use the registry created by this template."
      }
    },
    "frontendImageReference": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional frontend container image reference. Leave empty to use the registry created by this template."
      }
    },
    "frontendPublicApiBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Public API base URL baked into the frontend image at build time. Keep this aligned with the image tag deployed here."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Optional tags applied to all resources."
      }
    },
    "containerRegistrySubscriptionId": {
      "type": "string",
      "defaultValue": "[subscription().subscriptionId]",
      "metadata": {
        "description": "Optional subscription ID where the Azure Container Registry is located. Only used when containerRegistryName is provided."
      }
    },
    "containerRegistryResourceGroupName": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Optional resource group name where the Azure Container Registry is located. Defaults to the deployment resource group so role assignments stay in scope."
      }
    },
    "containerRegistryName": {
      "type": "string",
      "defaultValue": "[toLower(format('acr{0}', uniqueString(resourceGroup().id, parameters('location'))))]",
      "metadata": {
        "description": "Optional Azure Container Registry name. When supplied, the template assigns AcrPull to the web apps using managed identity."
      }
    },
    "containerRegistrySkuName": {
      "type": "string",
      "defaultValue": "Basic",
      "metadata": {
        "description": "Azure Container Registry SKU."
      }
    },
    "backendPort": {
      "type": "int",
      "defaultValue": 8080,
      "metadata": {
        "description": "Backend container port exposed by the image."
      }
    },
    "frontendPort": {
      "type": "int",
      "defaultValue": 3000,
      "metadata": {
        "description": "Frontend container port exposed by the image."
      }
    }
  },
  "variables": {
    "usePrivateRegistry": "[and(not(empty(parameters('containerRegistryName'))), not(empty(parameters('containerRegistryResourceGroupName'))))]",
    "containerRegistryLoginServer": "[format('{0}.azurecr.io', parameters('containerRegistryName'))]",
    "backendImageReferenceResolved": "[if(empty(parameters('backendImageReference')), format('{0}/{1}:{2}', variables('containerRegistryLoginServer'), parameters('backendImageRepository'), parameters('backendImageTag')), parameters('backendImageReference'))]",
    "frontendImageReferenceResolved": "[if(empty(parameters('frontendImageReference')), format('{0}/{1}:{2}', variables('containerRegistryLoginServer'), parameters('frontendImageRepository'), parameters('frontendImageTag')), parameters('frontendImageReference'))]",
    "backendAppSettings": "[union(createObject('WEBSITES_PORT', string(parameters('backendPort')), 'WEBSITES_ENABLE_APP_SERVICE_STORAGE', 'false', 'ASPNETCORE_ENVIRONMENT', 'Production'), createObject())]",
    "frontendAppSettings": "[union(createObject('WEBSITES_PORT', string(parameters('frontendPort')), 'WEBSITES_ENABLE_APP_SERVICE_STORAGE', 'false', 'NODE_ENV', 'production'), if(empty(parameters('frontendPublicApiBaseUrl')), createObject(), createObject('NEXT_PUBLIC_API_BASE_URL', parameters('frontendPublicApiBaseUrl'))))]"
  },
  "resources": [
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[parameters('containerRegistryName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('containerRegistrySkuName')]"
      },
      "properties": {
        "adminUserEnabled": false,
        "publicNetworkAccess": "Enabled",
        "policies": {
          "quarantinePolicy": {
            "status": "disabled"
          },
          "trustPolicy": {
            "type": "Notary",
            "status": "disabled"
          },
          "retentionPolicy": {
            "days": 7,
            "status": "disabled"
          }
        }
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "B1",
        "tier": "Basic",
        "size": "B1",
        "family": "B",
        "capacity": 1
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('backendAppName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "app,linux,container",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "http20Enabled": true,
          "minTlsVersion": "1.2",
          "scmMinTlsVersion": "1.2",
          "healthCheckPath": "/api/health",
          "linuxFxVersion": "[format('DOCKER|{0}', variables('backendImageReferenceResolved'))]",
          "acrUseManagedIdentityCreds": "[variables('usePrivateRegistry')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('backendAppName'), 'appsettings')]",
      "properties": "[variables('backendAppSettings')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('backendAppName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('frontendAppName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "app,linux,container",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "alwaysOn": true,
          "ftpsState": "Disabled",
          "http20Enabled": true,
          "minTlsVersion": "1.2",
          "scmMinTlsVersion": "1.2",
          "healthCheckPath": "/",
          "linuxFxVersion": "[format('DOCKER|{0}', variables('frontendImageReferenceResolved'))]",
          "acrUseManagedIdentityCreds": "[variables('usePrivateRegistry')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('frontendAppName'), 'appsettings')]",
      "properties": "[variables('frontendAppSettings')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('frontendAppName'))]"
      ]
    },
    {
      "condition": "[variables('usePrivateRegistry')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "acrPullRoleAssignments",
      "subscriptionId": "[parameters('containerRegistrySubscriptionId')]",
      "resourceGroup": "[parameters('containerRegistryResourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "containerRegistryName": {
            "value": "[parameters('containerRegistryName')]"
          },
          "backendPrincipalId": {
            "value": "[reference(resourceId('Microsoft.Web/sites', parameters('backendAppName')), '2023-12-01', 'full').identity.principalId]"
          },
          "frontendPrincipalId": {
            "value": "[reference(resourceId('Microsoft.Web/sites', parameters('frontendAppName')), '2023-12-01', 'full').identity.principalId]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.43.8.12551",
              "templateHash": "8160216301074588486"
            }
          },
          "parameters": {
            "containerRegistryName": {
              "type": "string",
              "metadata": {
                "description": "Azure Container Registry name."
              }
            },
            "backendPrincipalId": {
              "type": "string",
              "metadata": {
                "description": "Principal ID of the backend web app managed identity."
              }
            },
            "frontendPrincipalId": {
              "type": "string",
              "metadata": {
                "description": "Principal ID of the frontend web app managed identity."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName'))]",
              "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), parameters('backendPrincipalId'), 'AcrPull')]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
                "principalId": "[parameters('backendPrincipalId')]",
                "principalType": "ServicePrincipal"
              }
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName'))]",
              "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), parameters('frontendPrincipalId'), 'AcrPull')]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
                "principalId": "[parameters('frontendPrincipalId')]",
                "principalType": "ServicePrincipal"
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('backendAppName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('frontendAppName'))]"
      ]
    }
  ],
  "outputs": {
    "appServicePlanId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
    },
    "containerRegistryLoginServer": {
      "type": "string",
      "value": "[variables('containerRegistryLoginServer')]"
    },
    "backendHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('backendAppName')), '2023-12-01').defaultHostName]"
    },
    "frontendHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('frontendAppName')), '2023-12-01').defaultHostName]"
    },
    "backendUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('backendAppName')), '2023-12-01').defaultHostName)]"
    },
    "frontendUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', parameters('frontendAppName')), '2023-12-01').defaultHostName)]"
    }
  }
}