      "type": "int",
      "defaultValue": 8080,
      "metadata": {
        "description": "Backend container port exposed by the image."
      }
    },
    "frontendPort": {
      "type": "int",
      "defaultValue": 3000,
      "metadata": {
        "description": "Frontend container port exposed by the image."
